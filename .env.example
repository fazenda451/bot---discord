# Token do teu bot do Discord (obrigatório)
DISCORD_TOKEN=SEU_TOKEN_AQUI

# ID do canal onde os horários serão enviados (opcional, só para referência)
SCHEDULE_CHANNEL_ID=0

# Fuso horário (ex: Europe/Lisbon, America/Sao_Paulo, UTC)
TIMEZONE=Europe/Lisbon

# Cargos da org verificados pelo /pendentes (separados por vírgula)
# Podes usar o nome exato do cargo ou o ID numérico (mais fiável)
PENDENTES_CARGOS=🚗︙Membro,[🔝] Promessa
